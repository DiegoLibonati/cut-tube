#!/bin/sh
# Pre-commit hook for Cut Tube monorepo.
# Runs the Python pre-commit (ruff/mypy) when cut-tube-api files are staged.
# Runs lint-staged when cut-tube-app files are staged.

REPO_ROOT="$(git rev-parse --show-toplevel)"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

API_FILES=$(echo "$STAGED_FILES" | grep "^cut-tube-api/")
APP_FILES=$(echo "$STAGED_FILES" | grep "^cut-tube-app/")

EXIT_CODE=0

if [ -n "$API_FILES" ]; then
    echo "[pre-commit] Running ruff checks for cut-tube-api..."
    INSTALL_PYTHON="$REPO_ROOT/cut-tube-api/venv/Scripts/python.exe"
    if [ -x "$INSTALL_PYTHON" ]; then
        "$INSTALL_PYTHON" -mpre_commit run \
            --config="$REPO_ROOT/cut-tube-api/.pre-commit-config.yaml" \
            --hook-stage=pre-commit
    elif command -v pre-commit > /dev/null; then
        pre-commit run \
            --config="$REPO_ROOT/cut-tube-api/.pre-commit-config.yaml" \
            --hook-stage=pre-commit
    else
        echo '[pre-commit] `pre-commit` not found. Did you forget to activate your virtualenv?' 1>&2
        exit 1
    fi
    EXIT_CODE=$((EXIT_CODE + $?))
fi

if [ -n "$APP_FILES" ]; then
    echo "[pre-commit] Running lint-staged for cut-tube-app..."
    if command -v npx > /dev/null; then
        (cd "$REPO_ROOT/cut-tube-app" && npx --no-install lint-staged)
    else
        echo '[pre-commit] `npx` not found. Did you install Node.js?' 1>&2
        exit 1
    fi
    EXIT_CODE=$((EXIT_CODE + $?))
fi

exit $EXIT_CODE
